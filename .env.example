# ─────────────────────────────────────────────────────────────────────────────
# Public (exposed to the browser bundle — never put secrets here)
# ─────────────────────────────────────────────────────────────────────────────

# Application
NEXT_PUBLIC_APP_NAME=Kifpadel
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# Supabase URL — provide ONE of the following:
#   1. The full URL (preferred)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
#   2. ...or just the project id and the URL is derived as
#      https://<id>.supabase.co. The project id is not secret.
# NEXT_PUBLIC_SUPABASE_PROJECT_ID=your-project-id

# Supabase publishable / anon key — provide ONE of the following.
# Both refer to the same key class; "publishable" is Supabase's modern name.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ─────────────────────────────────────────────────────────────────────────────
# Server-only (must NOT be prefixed with NEXT_PUBLIC_)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase service-role / secret key — provide ONE of the following.
# Used by background jobs and admin operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_SECRET_KEY=your-secret-key

# Shared secret required by /api/webhooks/supabase.
SUPABASE_WEBHOOK_SECRET=your-webhook-secret

# One-time server-only secret used to promote the first platform super admin.
SUPER_ADMIN_ONBOARDING_KEY=your-super-admin-onboarding-secret
